# ── ECG Project — Environment Variables Template ──────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is listed in .gitignore.
# ──────────────────────────────────────────────────────────────────────────

# ── MongoDB Atlas ─────────────────────────────────────────────────────────
# Get this from: Atlas → Connect → Drivers → Python
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/ecg_db
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/ecg_db?retryWrites=true&w=majority

# ── JWT Auth (Cloud API) ──────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_a_long_random_secret_string

# ── Flask ─────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=replace_with_flask_secret

# ── RPi ↔ Render shared secret (Edge Key) ────────────────────────────────
# Same value must be set on BOTH the RPi .env and Render dashboard env vars.
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
EDGE_KEY=replace_with_shared_secret_between_rpi_and_render

# ── RPi Edge Device Identity ──────────────────────────────────────────────
# Human-readable unique ID for this Raspberry Pi unit.
# Admin maps this to a room number via POST /api/admin/assign-device.
# Example: rpi-room-101, rpi-icu-03
EDGE_DEVICE_ID=rpi-room-101

# ── RPi Serial Port ───────────────────────────────────────────────────────
# Check with: ls /dev/tty*  (after plugging ESP32 via USB)
# Linux (RPi): /dev/ttyUSB0 or /dev/ttyACM0
# Windows (dev): COM3, COM4, etc.
SERIAL_PORT=/dev/ttyUSB0

# ── Cloud API URL (set on RPi only) ───────────────────────────────────────
# The deployed Render URL of cloud_api.py.
# RPi posts summaries + alerts here after each inference window.
CLOUD_API_URL=https://<your-render-app>.onrender.com

# ── Frontend (Vite / React) ───────────────────────────────────────────────
# Set this in Vercel dashboard env vars (not in a committed file).
VITE_API_BASE_URL=https://<your-render-app>.onrender.com
